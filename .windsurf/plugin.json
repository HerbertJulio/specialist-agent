{
  "$schema": "https://windsurf.io/schemas/plugin-v1.json",
  "id": "specialist-agent",
  "name": "Specialist Agent",
  "version": "2.11.3",
  "description": "Your AI development team. 36 agents and 32 skills that build, review, debug, and ship production code.",
  "author": {
    "name": "Herbert Julio",
    "email": "herbertjulio@gmail.com",
    "url": "https://github.com/HerbertJulio"
  },
  "repository": "https://github.com/HerbertJulio/specialist-agent",
  "documentation": "https://specialistagent.com.br/",
  "license": "MIT",
  "keywords": [
    "ai-agents",
    "vue",
    "react",
    "nextjs",
    "svelte",
    "code-generation",
    "tdd",
    "code-review",
    "debugging",
    "performance"
  ],
  "engines": {
    "windsurf": ">=1.0.0"
  },
  "categories": [
    "AI",
    "Code Generation",
    "Developer Tools"
  ],
  "capabilities": {
    "prompts": true,
    "agents": true,
    "skills": true
