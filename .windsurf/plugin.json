  "profiles": {
    "startup-fast": {
      "description": "Move fast, Haiku model",
      "model": "haiku",
      "validation": "minimal"
    },
    "enterprise-strict": {
      "description": "Full validation",
      "model": "sonnet",
      "validation": "full"
    },
    "learning-mode": {
      "description": "Explain everything",
      "model": "sonnet",
      "explain": true
    },
    "cost-optimized": {
      "description": "Minimize tokens",
      "model": "haiku",
      "validation": "minimal"
    }
  },
